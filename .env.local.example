# ─── Database (Neon PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── NextAuth ─────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ─── OAuth Providers ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key

# ─── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_pro_monthly_id
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_monthly_id

# ─── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Topic library (numerology / health scripts from a Google Sheet) ───────
# Read via the opensheet.elk.sh JSON proxy (public sheet, no API key needed).
# Defaults to the thansohoc sheet + tab "Sheet1" if unset.
TOPICS_SHEET_ID=1-aRNnvyv70nx_dsrEOR1_nO3l6643LjOaQh6uHm6rpE
# One tab:
TOPICS_SHEET_TAB=Sheet1
# …or MANY tabs (one per content type) — comma-separated, takes priority:
# TOPICS_SHEET_TABS=ThanSoHoc,SucKhoe,KyNangSong

# ─── Claude (script generation, optional — best quality) ──────────────────
ANTHROPIC_API_KEY=sk-ant-your-key
# CLAUDE_MODEL=claude-opus-4-8
